# Branch-specific secrets — generated per branch from this template.
# Placeholders: ${BRANCH_SLUG}
# Shared staging secrets (SENTRY_DSN, MAILER_DSN, ...) come from secrets-sops.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: app-branch-secret
type: Opaque
stringData:
  APP_SECRET: staging-branch-${BRANCH_SLUG}
